{#
/**
 * @file
 * Template for the Wink Content block.
 *
 * Available variables:
 *  - layout: The Wink layout ID string (sanitised server-side).
 *  - id:     The Wink content identifier string (sanitised server-side).
 *
 * @ingroup themeable
 */
#}
<wink-content-loader layout="{{ layout }}" id="{{ id }}"></wink-content-loader>
